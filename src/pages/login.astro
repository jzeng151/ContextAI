---
const apiUrl = (import.meta.env.PUBLIC_CONTEXTAI_API_URL ?? "http://127.0.0.1:4000").replace(/\/$/, "");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>Sign in · ContextAI</title>
  </head>
  <body data-api-origin={apiUrl}>
    <main>
      <a class="brand" href="/" aria-label="ContextAI home"><span aria-hidden="true">C</span><strong>ContextAI</strong></a>
      <section aria-labelledby="login-title">
        <p>RevOps administration</p>
        <h1 id="login-title">Sign in to the demo</h1>
        <span>Enter the administrator bootstrap token supplied with this environment.</span>
        <form novalidate>
          <label for="bootstrap-token">Bootstrap token</label>
          <input id="bootstrap-token" name="bootstrapToken" type="password" autocomplete="off" autocapitalize="none" spellcheck="false" required autofocus />
          <button type="submit">Sign in</button>
          <output role="alert" aria-live="polite"></output>
        </form>
      </section>
    </main>

    <script>
      import { safeReturnTo } from "../lib/login.ts";

      const form = document.querySelector<HTMLFormElement>("form")!;
      const input = document.querySelector<HTMLInputElement>("#bootstrap-token")!;
      const output = document.querySelector<HTMLOutputElement>("output")!;
      const button = document.querySelector<HTMLButtonElement>("button")!;
      const apiOrigin = document.body.dataset.apiOrigin?.replace(/\/$/, "") ?? "";
      const returnTo = safeReturnTo(new URLSearchParams(location.search).get("returnTo"), location.origin);

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;
        button.disabled = true;
        output.value = "Signing in…";
        try {
          const response = await fetch(`${apiOrigin}/auth/session`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ bootstrapToken: input.value }),
          });
          const result = await response.json() as { token?: string; expiresAt?: string };
          input.value = "";
          if (!response.ok || !result.token || !result.expiresAt || Date.parse(result.expiresAt) <= Date.now()) throw new Error();
          sessionStorage.setItem("contextai.session-token", result.token);
          location.assign(returnTo);
        } catch {
          input.value = "";
          button.disabled = false;
          output.value = "Sign-in failed. Check the token and try again.";
          input.focus();
        }
      });
    </script>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; margin: 0; }
  :root { font-family: Inter, ui-sans-serif, system-ui, sans-serif; color: #17211d; background: #f3f6f4; --muted: #52635b; --line: #cbd5d0; --accent: #167052; --accent-dark: #0f563f; }
  :global(body) { min-width: 320px; min-height: 100dvh; display: grid; place-items: center; padding: 24px; font-size: 14px; line-height: 1.5; }
  main { width: min(100%, 420px); }
  .brand { display: inline-flex; align-items: center; gap: 9px; margin-bottom: 20px; color: #17211d; text-decoration: none; }.brand span { width: 30px; height: 30px; display: grid; place-items: center; border-radius: 5px; color: #13241d; background: #8fd0b8; font-weight: 900; }
  section { padding: 28px; border: 1px solid var(--line); background: white; }
  section > p { color: var(--accent-dark); font-size: 12px; font-weight: 800; }
  h1 { margin-top: 2px; font-size: 28px; letter-spacing: -.025em; text-wrap: balance; }
  section > span { display: block; max-width: 52ch; margin-top: 6px; color: var(--muted); text-wrap: pretty; }
  form { display: grid; gap: 9px; margin-top: 24px; }
  label { color: var(--muted); font-size: 12px; font-weight: 700; }
  input, button { min-height: 42px; border-radius: 5px; font: inherit; }
  input { width: 100%; padding: 0 10px; border: 1px solid #879990; color: #17211d; background: white; }
  button { margin-top: 3px; padding: 0 14px; border: 1px solid var(--accent); color: white; background: var(--accent); font-weight: 800; cursor: pointer; }
  button:hover { background: var(--accent-dark); }
  button:disabled { cursor: wait; opacity: .65; }
  input:focus-visible, button:focus-visible, .brand:focus-visible { outline: 3px solid #73b79f; outline-offset: 2px; }
  output { min-height: 21px; color: #9b2c2c; font-size: 12px; }
  @media (max-width: 460px) { :global(body) { align-items: start; padding: 18px 12px; } section { padding: 22px 18px; } }
</style>
