---
import { leads } from "../data/leads";
import { compareConfigs, defaultConfigVersion, type ConfigSection } from "../lib/config";

const draft = {
  ...defaultConfigVersion,
  id: "score-v0.2-draft",
  author: "Maya Chen",
  createdAt: "2026-07-12T14:30:00.000Z",
  status: "draft" as const,
  changeSummary: "Tighten warm qualification and shorten intent freshness.",
  adminNotes: "Pilot change for review before the Monday run.",
  config: {
    ...defaultConfigVersion.config,
    bandThresholds: { ...defaultConfigVersion.config.bandThresholds, Warm: 65 },
    freshness: { ...defaultConfigVersion.config.freshness, intent: { freshThroughDays: 21 } }
  }
};
const changed = compareConfigs(defaultConfigVersion.config, draft.config);
const audits = leads.map((lead) => ({
  lead,
  evidence: lead.allowed_claims.flatMap(({ evidence_ids }) => evidence_ids).length,
  claims: lead.allowed_claims.length,
  policy: lead.writeback_plan?.decision ?? "Unavailable",
  outcome: lead.writeback_outcome.status
}));
const sections: Readonly<Record<ConfigSection, string>> = {
  categoryWeights: "Score weights",
  bandThresholds: "Bands",
  confidenceRules: "Confidence",
  manualReview: "Manual review",
  freshness: "Freshness",
  sourcePolicy: "Approved sources",
  weakSignals: "Weak signals",
  writeback: "Writeback"
};
const label = (value: string) => value.replaceAll("_", " ").replaceAll(/\b\w/g, (letter) => letter.toUpperCase());
const date = (value: string) => new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric", hour: "numeric", minute: "2-digit", timeZone: "UTC" }).format(new Date(value));
const governanceApiUrl = import.meta.env.PUBLIC_CONTEXTAI_API_URL ?? "";
const requiredSources = new Set(["crm", "intent", "engagement", "public_signal"]);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>RevOps governance · ContextAI</title>
  </head>
  <body data-api-origin={governanceApiUrl}>
    <a class="skip-link" href="#admin-main">Skip to governance workspace</a>
    <div class="shell">
      <aside class="nav" aria-label="ContextAI navigation">
        <a class="brand" href="/"><span aria-hidden="true">C</span><strong>ContextAI</strong></a>
        <nav>
          <a href="/">Lead queue</a>
          <a class="active" href="/admin" aria-current="page">Governance</a>
        </nav>
        <div class="account"><span aria-hidden="true">MC</span><p><strong>Maya Chen</strong><small>RevOps Admin</small></p></div>
      </aside>

      <main id="admin-main">
        <header class="page-header">
          <div><p>RevOps governance</p><h1>Policy control room</h1><span>Inspect every rule change and reverse CRM writes without touching code.</span></div>
          <div class="active-version"><span>Active configuration</span><strong>{defaultConfigVersion.id}</strong><small>Published {date(defaultConfigVersion.createdAt)}</small></div>
        </header>

        <nav class="section-nav" aria-label="Governance sections">
          <a href="#configuration">Configuration</a><a href="#history">History</a><a href="#review">Manual review</a><a href="#audit">Audit</a><a href="#integrations">Integrations</a>
        </nav>

        <section class="summary" aria-label="Governance status">
          <div><strong>{changed.length}</strong><span>draft sections changed</span></div>
          <div><strong data-review-count>—</strong><span>open review reasons</span></div>
          <div><strong>{audits.length}</strong><span>evaluation traces</span></div>
          <div class="healthy"><strong>Protected</strong><span>admin role + immutable history</span></div>
        </section>

        <section id="configuration" class="workspace" aria-labelledby="configuration-title">
          <div class="section-heading"><div><h2 id="configuration-title">Draft configuration</h2><p>Only safe policy values can be published. Historical evaluations keep their original version.</p></div><span class="status draft">Draft</span></div>
          <form id="config-form" data-active-config={JSON.stringify(defaultConfigVersion.config)} novalidate>
            <div class="editor">
              <fieldset data-config-section="categoryWeights">
                <legend>Score weights <span>must total 100</span></legend>
                <div class="field-grid">
                  {Object.entries(draft.config.categoryWeights).map(([name, value]) => <label><span>{label(name)}</span><input type="number" name={`categoryWeights.${name}`} min="0" max="100" value={value} /></label>)}
                </div>
                <output class="inline-status" data-weight-total>100 / 100</output>
              </fieldset>

              <fieldset data-config-section="bandThresholds">
                <legend>Numeric bands <span>Cold &lt; Warm &lt; Hot</span></legend>
                <div class="field-grid three">
                  {Object.entries(draft.config.bandThresholds).map(([name, value]) => <label><span>{name}</span><input type="number" name={`bandThresholds.${name}`} min="0" max="100" value={value} /></label>)}
                </div>
              </fieldset>

              <fieldset data-config-section="freshness">
                <legend>Freshness thresholds <span>whole days</span></legend>
                <div class="field-grid three">
                  <label><span>Intent</span><input type="number" name="freshness.intent.freshThroughDays" min="0" value={draft.config.freshness.intent.freshThroughDays} /></label>
                  <label><span>Engagement</span><input type="number" name="freshness.engagement.freshThroughDays" min="0" value={draft.config.freshness.engagement.freshThroughDays} /></label>
                  <label><span>Public signal</span><input type="number" name="freshness.publicSignal.freshThroughDays" min="0" value={draft.config.freshness.publicSignal.freshThroughDays} /></label>
                  <label><span>Firmographic fresh</span><input type="number" name="freshness.firmographic.freshThroughDays" min="0" value={draft.config.freshness.firmographic.freshThroughDays} /></label>
                  <label><span>Firmographic stale</span><input type="number" name="freshness.firmographic.staleAfterDays" min="0" value={draft.config.freshness.firmographic.staleAfterDays} /></label>
                  <label><span>Manual review after</span><input type="number" name="freshness.contact.manualReviewAfterDays" min="0" value={draft.config.freshness.contact.manualReviewAfterDays} /></label>
                </div>
              </fieldset>

              <fieldset data-config-section="sourcePolicy">
                <legend>Approved evidence sources</legend>
                <div class="check-grid">
                  {draft.config.sourcePolicy.approvedSourceTypes.map((source) => <label><input type="checkbox" name="approvedSources" value={source} checked disabled={requiredSources.has(source)} /><span>{label(source)}{requiredSources.has(source) ? " · Required" : ""}</span></label>)}
                </div>
              </fieldset>

              <fieldset data-config-section="weakSignals">
                <legend>Weak-signal safety</legend>
                <div class="locked-rule"><div><strong>Email opens stay weak engagement</strong><p>They cannot count as buying intent or produce Hot alone.</p></div><span>Locked</span></div>
              </fieldset>

              <fieldset data-config-section="writeback">
                <legend>Writeback governance</legend>
                <div class="split-fields">
                  <label><span>Contact allowlist</span><textarea name="writeback.allowlist.contact" rows="5">{draft.config.writeback.allowlist.contact.join("\n")}</textarea></label>
                  <label><span>Company allowlist</span><textarea name="writeback.allowlist.company" rows="5">{draft.config.writeback.allowlist.company.join("\n")}</textarea></label>
                  <label><span>Contact fields requiring approval</span><textarea name="writeback.manualApprovalFields.contact" rows="3" placeholder="One allowlisted field per line">{draft.config.writeback.manualApprovalFields.contact.join("\n")}</textarea></label>
                  <label><span>Company fields requiring approval</span><textarea name="writeback.manualApprovalFields.company" rows="3" placeholder="One allowlisted field per line">{draft.config.writeback.manualApprovalFields.company.join("\n")}</textarea></label>
                </div>
              </fieldset>
            </div>

            <aside class="publish-panel" aria-labelledby="compare-title">
              <div><span>Compare with active</span><h3 id="compare-title">{draft.id}</h3><p>{draft.changeSummary}</p></div>
              <input type="hidden" name="changeSummary" value={draft.changeSummary} />
              <ul data-change-list>{changed.map((section) => <li data-change={section}><strong>{sections[section]}</strong><span>Changed</span></li>)}</ul>
              <label><span>Admin notes</span><textarea name="adminNotes" rows="4" required>{draft.adminNotes}</textarea></label>
              <div class="error" data-config-error role="alert" hidden></div>
              <button type="submit">Validate and publish</button>
              <output data-publish-status aria-live="polite">No changes published.</output>
            </aside>
          </form>
        </section>

        <section id="history" aria-labelledby="history-title">
          <div class="section-heading"><div><h2 id="history-title">Version history</h2><p>Version content is immutable; publishing only changes which version is active.</p></div></div>
          <div class="table-wrap"><table><thead><tr><th>Version</th><th>Status</th><th>Author</th><th>Created</th><th>Changed rules</th><th>Admin notes</th></tr></thead><tbody data-history-body>
            <tr><td><strong>{draft.id}</strong></td><td><span class="status draft">Draft</span></td><td>{draft.author}</td><td>{date(draft.createdAt)}</td><td>{changed.map((item) => sections[item]).join(", ")}</td><td>{draft.adminNotes}</td></tr>
            <tr><td><strong>{defaultConfigVersion.id}</strong></td><td><span class="status active">Active</span></td><td>{defaultConfigVersion.author}</td><td>{date(defaultConfigVersion.createdAt)}</td><td>Initial policy</td><td>{defaultConfigVersion.adminNotes}</td></tr>
          </tbody></table></div>
        </section>

        <section id="review" aria-labelledby="review-title">
          <div class="section-heading"><div><h2 id="review-title">Manual-review queue</h2><p>Resolve or dismiss one reason at a time. Every decision records the actor, note, and timestamp.</p></div><span class="status warning"><span data-review-count>—</span>&nbsp;open</span></div>
          <div class="review-list" data-review-list><div class="empty"><strong>Loading review queue</strong><p>Reading persisted review items.</p></div></div>
          <template id="review-item-template"><article data-review-item><div><strong data-review-company></strong><span data-review-lead></span></div><div><strong data-review-reason></strong><span data-review-detail></span></div><form data-review-form><label><span>Decision note</span><input name="note" required placeholder="What was verified or corrected?" /></label><button name="decision" value="resolved">Resolve</button><button class="secondary" name="decision" value="dismissed">Dismiss</button><output data-review-status aria-live="polite"></output></form></article></template>
        </section>

        <section id="audit" aria-labelledby="audit-title">
          <div class="section-heading"><div><h2 id="audit-title">Decision and writeback audit</h2><p>Trace version, evidence, claim, policy, actor, and outcome for every evaluated lead.</p></div></div>
          <div class="table-wrap"><table><thead><tr><th>Evaluation</th><th>Version</th><th>Evidence / claims</th><th>Writeback policy</th><th>Outcome</th><th>Rollback</th></tr></thead><tbody data-audit-body>
            {audits.map(({ lead, evidence, claims, policy, outcome }) => <tr><td><strong>{lead.lead_identity.company}</strong><span>{lead.evaluation_id}</span></td><td>{lead.score_version}</td><td>{evidence} / {claims}</td><td>{policy}</td><td>{outcome}</td><td><div class="row-actions"><button type="button" class="secondary" data-rollback-field disabled={outcome !== "Written"}>Field</button><button type="button" class="secondary" data-rollback-lead disabled={outcome !== "Written"}>Lead</button></div></td></tr>)}
          </tbody></table></div>
        </section>

        <section id="integrations" aria-labelledby="integrations-title">
          <div class="section-heading"><div><h2 id="integrations-title">Integration health</h2><p>Connection health is visible here; credential revocation remains in the security-owned control.</p></div></div>
          <div class="integration-actions"><button type="button" data-connect-hubspot>Connect HubSpot</button><output data-hubspot-status role="status" aria-live="polite"></output></div>
          <div data-integration-list><article class="integration-row"><div class="provider"><span aria-hidden="true">H</span><div><strong>HubSpot</strong><small>Pilot CRM · OAuth reconnect required</small></div></div><div><span class="status warning">Disconnected</span><small>Last error: oauth_reconnect_required</small></div><a href="https://github.com/jzeng151/ContextAI/blob/main/SECURITY.md">Disconnect and revoke controls</a></article></div>
        </section>
      </main>
    </div>

    <script>
      type Version = { id: string; author: string; createdAt: string; status: "draft" | "active" | "inactive"; changeSummary: string; adminNotes: string; config: Record<string, any> };
      type Review = { review_id: string; evaluation_id: string; reason: string; payload: Record<string, any> };
      type Integration = { provider: string; external_account_id: string; status: string; last_health_at: string | null; last_error: string | null };
      const configForm = document.querySelector<HTMLFormElement>("#config-form")!;
      const total = document.querySelector<HTMLOutputElement>("[data-weight-total]");
      const error = document.querySelector<HTMLElement>("[data-config-error]");
      const status = document.querySelector<HTMLOutputElement>("[data-publish-status]");
      const reviewList = document.querySelector<HTMLElement>("[data-review-list]")!;
      const reviewCounts = document.querySelectorAll<HTMLElement>("[data-review-count]");
      const auditBody = document.querySelector<HTMLTableSectionElement>("[data-audit-body]")!;
      const historyBody = document.querySelector<HTMLTableSectionElement>("[data-history-body]")!;
      const integrationList = document.querySelector<HTMLElement>("[data-integration-list]")!;
      const connectHubSpot = document.querySelector<HTMLButtonElement>("[data-connect-hubspot]")!;
      const hubSpotStatus = document.querySelector<HTMLOutputElement>("[data-hubspot-status]")!;
      const apiOrigin = document.body.dataset.apiOrigin?.replace(/\/$/, "") ?? "";
      const token = () => sessionStorage.getItem("contextai.session-token");
      let redirectingToLogin = false;
      const redirectToLogin = () => {
        if (redirectingToLogin) return;
        redirectingToLogin = true;
        sessionStorage.removeItem("contextai.session-token");
        location.assign(`/login?returnTo=${encodeURIComponent(location.pathname + location.search + location.hash)}`);
      };
      const api = async <T,>(path: string, init: RequestInit = {}) => {
        const sessionToken = token();
        if (!sessionToken) { redirectToLogin(); throw new Error("Authentication required"); }
        const response = await fetch(`${apiOrigin}${path}`, { ...init, headers: { "Authorization": `Bearer ${sessionToken}`, ...(init.body ? { "Content-Type": "application/json" } : {}), ...(init.headers ?? {}) } });
        if (response.status === 401) { redirectToLogin(); throw new Error("Authentication required"); }
        const result = await response.json() as T & { error?: string };
        if (!response.ok) throw new Error(result.error || "Governance request failed.");
        return result;
      };
      const callbackStatus = new URLSearchParams(location.search).get("hubspot");
      if (callbackStatus === "connected") hubSpotStatus.value = "HubSpot connected successfully.";
      else if (callbackStatus === "error") hubSpotStatus.value = "HubSpot could not be connected. Try again.";
      connectHubSpot.addEventListener("click", async () => {
        connectHubSpot.disabled = true;
        hubSpotStatus.value = "Opening HubSpot authorization…";
        try {
          const { authorizationUrl } = await api<{ authorizationUrl: string }>("/oauth/hubspot/start", { method: "POST" });
          const destination = new URL(authorizationUrl);
          if (destination.origin !== "https://app.hubspot.com") throw new Error("Unexpected authorization destination");
          location.assign(destination.toString());
        } catch {
          if (!redirectingToLogin) { connectHubSpot.disabled = false; hubSpotStatus.value = "HubSpot connection could not start."; }
        }
      });
      let activeConfig = JSON.parse(configForm.dataset.activeConfig || "{}") as Record<string, any>;
      const changedSections = new Set(Array.from(document.querySelectorAll<HTMLElement>("[data-change]")).map((item) => item.dataset.change));
      const refreshWeights = () => {
        const weights = Array.from(configForm.querySelectorAll<HTMLInputElement>('[name^="categoryWeights."]'));
        const sum = weights.reduce((value, input) => value + Number(input.value), 0);
        if (total) { total.value = `${sum} / 100`; total.classList.toggle("invalid", sum !== 100); }
        return sum;
      };
      const setValue = (name: string, value: unknown) => { const input = configForm.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null; if (input) input.value = String(value); };
      const applyConfig = (version: Version) => {
        activeConfig = structuredClone(version.config);
        configForm.dataset.activeConfig = JSON.stringify(activeConfig);
        Object.entries(activeConfig.categoryWeights).forEach(([name, value]) => setValue(`categoryWeights.${name}`, value));
        Object.entries(activeConfig.bandThresholds).forEach(([name, value]) => setValue(`bandThresholds.${name}`, value));
        for (const name of ["intent", "engagement", "publicSignal"]) setValue(`freshness.${name}.freshThroughDays`, activeConfig.freshness[name].freshThroughDays);
        setValue("freshness.firmographic.freshThroughDays", activeConfig.freshness.firmographic.freshThroughDays);
        setValue("freshness.firmographic.staleAfterDays", activeConfig.freshness.firmographic.staleAfterDays);
        setValue("freshness.contact.manualReviewAfterDays", activeConfig.freshness.contact.manualReviewAfterDays);
        configForm.querySelectorAll<HTMLInputElement>('[name="approvedSources"]').forEach((input) => input.checked = activeConfig.sourcePolicy.approvedSourceTypes.includes(input.value));
        for (const object of ["contact", "company"]) {
          setValue(`writeback.allowlist.${object}`, activeConfig.writeback.allowlist[object].join("\n"));
          setValue(`writeback.manualApprovalFields.${object}`, activeConfig.writeback.manualApprovalFields[object].join("\n"));
        }
        const active = document.querySelector<HTMLElement>(".active-version");
        if (active) { active.querySelector("strong")!.textContent = version.id; active.querySelector("small")!.textContent = `Published ${new Date(version.createdAt).toLocaleString()}`; }
        refreshWeights();
      };
      const configFromForm = (values: FormData) => {
        const config = structuredClone(activeConfig);
        for (const input of configForm.querySelectorAll<HTMLInputElement>('[name^="categoryWeights."], [name^="bandThresholds."], [name^="freshness."]')) {
          const path = input.name.split(".");
          let target = config;
          while (path.length > 1) target = target[path.shift()!];
          target[path[0]!] = Number(input.value);
        }
        const approvedSources = Array.from(configForm.querySelectorAll<HTMLInputElement>('[name="approvedSources"]:checked'), ({ value }) => value);
        config.sourcePolicy.approvedSourceTypes = approvedSources;
        for (const family of Object.keys(config.sourcePolicy.precedence)) config.sourcePolicy.precedence[family] = config.sourcePolicy.precedence[family].filter((source: string) => approvedSources.includes(source));
        config.writeback.approvedSourceTypes = config.writeback.approvedSourceTypes.filter((source: string) => approvedSources.includes(source));
        const lines = (name: string) => String(values.get(name) ?? "").split("\n").map((value) => value.trim()).filter(Boolean);
        for (const object of ["contact", "company"]) {
          config.writeback.allowlist[object] = lines(`writeback.allowlist.${object}`);
          config.writeback.manualApprovalFields[object] = lines(`writeback.manualApprovalFields.${object}`);
        }
        return config;
      };
      configForm.addEventListener("input", (event) => {
        const fieldset = (event.target as HTMLElement).closest<HTMLElement>("[data-config-section]");
        if (fieldset?.dataset.configSection) changedSections.add(fieldset.dataset.configSection);
        refreshWeights();
      });
      configForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const values = new FormData(configForm);
        const cold = Number(values.get("bandThresholds.Cold"));
        const warm = Number(values.get("bandThresholds.Warm"));
        const hot = Number(values.get("bandThresholds.Hot"));
        const message = refreshWeights() !== 100 ? "Score weights must total 100." : !(cold < warm && warm < hot) ? "Bands must remain in Cold, Warm, Hot order." : !String(values.get("adminNotes") ?? "").trim() ? "Admin notes are required." : "";
        if (error) { error.hidden = !message; error.textContent = message; }
        if (message) return;
        const submit = configForm.querySelector<HTMLButtonElement>('button[type="submit"]')!;
        submit.disabled = true;
        try {
          const key = "contextai.config-draft-id";
          const draftId = sessionStorage.getItem(key) || `score-${crypto.randomUUID()}`;
          sessionStorage.setItem(key, draftId);
          const result = await api<{ version: Version }>("/admin/config/publish", { method: "POST", body: JSON.stringify({ draftId, changeSummary: values.get("changeSummary"), adminNotes: values.get("adminNotes"), config: configFromForm(values) }) });
          sessionStorage.removeItem(key);
          applyConfig(result.version);
          if (status) status.value = `${result.version.id} is active and will be used for new evaluations.`;
        } catch (publishError) {
          if (error) { error.hidden = false; error.textContent = publishError instanceof Error ? publishError.message : "Publish failed."; }
        } finally { submit.disabled = false; }
      });
      const bindReview = (form: HTMLFormElement) => form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;
        const item = form.closest<HTMLElement>("[data-review-item]")!;
        const decision = ((event as SubmitEvent).submitter as HTMLButtonElement | null)?.value;
        const note = String(new FormData(form).get("note") ?? "").trim();
        const output = form.querySelector<HTMLOutputElement>("[data-review-status]");
        const controls = form.querySelectorAll<HTMLInputElement | HTMLButtonElement>("input, button");
        controls.forEach((control) => control.disabled = true);
        try {
          await api(`/admin/reviews/${encodeURIComponent(item.dataset.reviewId!)}/decision`, { method: "POST", body: JSON.stringify({ decision, note }) });
          item.setAttribute("data-closed", "true");
          if (output) output.value = decision === "resolved" ? "Resolved and audited." : "Dismissed and audited.";
          await loadReviews();
        } catch (reviewError) {
          controls.forEach((control) => control.disabled = false);
          if (output) output.value = reviewError instanceof Error ? reviewError.message : "Review decision failed.";
        }
      });
      const loadReviews = async () => {
        try {
          const { reviews } = await api<{ reviews: Review[] }>("/admin/reviews");
          reviewList.replaceChildren();
          reviewCounts.forEach((count) => count.textContent = String(reviews.length));
          for (const review of reviews) {
            const item = (document.querySelector<HTMLTemplateElement>("#review-item-template")!.content.firstElementChild!.cloneNode(true) as HTMLElement);
            item.dataset.reviewId = review.review_id;
            item.querySelector<HTMLElement>("[data-review-company]")!.textContent = review.payload.company || review.payload.accountId || "Unknown account";
            item.querySelector<HTMLElement>("[data-review-lead]")!.textContent = `${review.payload.leadName || "Unknown lead"} · ${review.payload.leadId || review.evaluation_id}`;
            item.querySelector<HTMLElement>("[data-review-reason]")!.textContent = review.reason.replaceAll("_", " ");
            item.querySelector<HTMLElement>("[data-review-detail]")!.textContent = review.payload.sourceConflicts?.[0] || review.payload.missingFields?.join(", ") || "Policy review required";
            bindReview(item.querySelector<HTMLFormElement>("[data-review-form]")!);
            reviewList.append(item);
          }
          if (!reviews.length) { const empty = document.createElement("div"); empty.className = "empty"; empty.textContent = "No open review items."; reviewList.append(empty); }
        } catch (reviewError) { reviewList.innerHTML = ""; const empty = document.createElement("div"); empty.className = "empty"; empty.textContent = reviewError instanceof Error ? reviewError.message : "Review queue unavailable."; reviewList.append(empty); }
      };
      const loadAudits = async () => {
        try {
          const { audits } = await api<{ audits: Array<Record<string, any>> }>("/admin/audits");
          const rows = audits.map((audit) => {
            const row = document.createElement("tr");
            for (const value of [audit.lead_id, audit.score_version, audit.field_name, audit.policy_version, audit.rollback_id ? "Rolled back" : audit.outcome]) { const cell = document.createElement("td"); cell.textContent = String(value); row.append(cell); }
            const actions = document.createElement("td"); actions.className = "row-actions";
            const rollbackable = audit.outcome === "Written" && audit.policy_version !== "legacy" && !audit.rollback_id && !String(audit.audit_id).startsWith("rollback:") && !String(audit.audit_id).startsWith("pending:");
            for (const [kind, text] of [["field", "Field"], ["lead", "Lead"]] as const) { const button = document.createElement("button"); button.type = "button"; button.className = "secondary"; button.dataset.rollback = kind; button.dataset.auditId = audit.audit_id; button.dataset.evaluationId = audit.evaluation_id; button.textContent = text; button.disabled = !rollbackable; actions.append(button); }
            row.append(actions); return row;
          });
          if (!rows.length) { const row = document.createElement("tr"); const cell = document.createElement("td"); cell.colSpan = 6; cell.className = "empty"; cell.textContent = "No persisted writeback audit records."; row.append(cell); rows.push(row); }
          auditBody.replaceChildren(...rows);
        } catch { /* Fixture audit remains visible when the runtime API is unavailable. */ }
      };
      auditBody.addEventListener("click", async (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-rollback]");
        if (!button || !confirm(`Roll back this ${button.dataset.rollback} write?`)) return;
        button.disabled = true;
        try {
          const path = button.dataset.rollback === "field" ? `/admin/writebacks/${encodeURIComponent(button.dataset.auditId!)}/rollback` : `/admin/evaluations/${encodeURIComponent(button.dataset.evaluationId!)}/rollback`;
          await api(path, { method: "POST" });
          await loadAudits();
        } catch (rollbackError) { button.disabled = false; alert(rollbackError instanceof Error ? rollbackError.message : "Rollback failed."); }
      });
      const loadConfig = async () => {
        try {
          const { versions } = await api<{ versions: Version[] }>("/admin/config");
          historyBody.replaceChildren(...versions.map((version) => {
            const row = document.createElement("tr");
            const versionCell = document.createElement("td"); const strong = document.createElement("strong"); strong.textContent = version.id; versionCell.append(strong); row.append(versionCell);
            const statusCell = document.createElement("td"); const badge = document.createElement("span"); badge.className = `status ${version.status}`; badge.textContent = version.status; statusCell.append(badge); row.append(statusCell);
            for (const value of [version.author, new Date(version.createdAt).toLocaleString(), version.changeSummary, version.adminNotes]) { const cell = document.createElement("td"); cell.textContent = value; row.append(cell); }
            return row;
          }));
          const active = versions.find((version) => version.status === "active");
          if (active) applyConfig(active);
        } catch { /* Static defaults remain visible until authentication is available. */ }
      };
      const loadIntegrations = async () => {
        try {
          const { integrations } = await api<{ integrations: Integration[] }>("/admin/integrations");
          const rows = integrations.map((integration) => {
            const row = document.createElement("article"); row.className = "integration-row";
            const provider = document.createElement("div"); provider.className = "provider"; const mark = document.createElement("span"); mark.ariaHidden = "true"; mark.textContent = integration.provider.slice(0, 1).toUpperCase(); const details = document.createElement("div"); const name = document.createElement("strong"); name.textContent = integration.provider; const account = document.createElement("small"); account.textContent = integration.external_account_id; details.append(name, account); provider.append(mark, details);
            const health = document.createElement("div"); const badge = document.createElement("span"); badge.className = `status ${integration.status === "active" ? "active" : "warning"}`; badge.textContent = integration.status; const detail = document.createElement("small"); detail.textContent = integration.last_error ? `Last error: ${integration.last_error}` : integration.last_health_at ? `Checked ${new Date(integration.last_health_at).toLocaleString()}` : "Health check pending"; health.append(badge, detail);
            const controls = document.createElement("a"); controls.href = "https://github.com/jzeng151/ContextAI/blob/main/SECURITY.md"; controls.textContent = "Disconnect and revoke controls"; row.append(provider, health, controls); return row;
          });
          if (!rows.length) { const empty = document.createElement("div"); empty.className = "empty"; empty.textContent = "No persisted integrations."; rows.push(empty); }
          integrationList.replaceChildren(...rows);
        } catch { /* Static integration guidance remains visible when the runtime API is unavailable. */ }
      };
      void Promise.all([loadConfig(), loadReviews(), loadAudits(), loadIntegrations()]);
    </script>
