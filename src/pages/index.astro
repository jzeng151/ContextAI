---
import { leads } from "../data/leads";
import { freshnessLabel, groundedHook, hasOnlyWeakOpenIntent, isWritebackEligible, scoreLabel, toolRun } from "../lib/contextai";

const selected = leads[0];
const hot = leads.filter((lead) => lead.band === "Hot").length;
const review = leads.filter((lead) => lead.band === "Needs Manual Review").length;
const writebackSafe = leads.filter(isWritebackEligible).length;
const totalScore = selected.scoreBreakdown.fit + selected.scoreBreakdown.intent + selected.scoreBreakdown.engagement + selected.scoreBreakdown.publicSignal;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>ContextAI Dashboard</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <div>
          <p class="eyebrow">ContextAI</p>
          <h1>Agentic lead triage dashboard</h1>
          <p>Vendor-neutral lead context, deterministic scoring, grounded hooks, and RevOps auditability in one view.</p>
        </div>
        <div class="run-card">
          <span>Latest run</span>
          <strong>Morning schedule</strong>
          <small>6 leads evaluated with required tool order</small>
        </div>
      </header>

      <section class="metrics" aria-label="Pipeline summary">
        <article><span>Processed</span><strong>{leads.length}</strong></article>
        <article><span>Hot leads</span><strong>{hot}</strong></article>
        <article><span>Manual review</span><strong>{review}</strong></article>
        <article><span>Writeback safe</span><strong>{writebackSafe}</strong></article>
      </section>

      <section class="split">
        <div>
          <div class="section-heading">
            <div>
              <p class="eyebrow">Rep queue</p>
              <h2>Prioritized leads</h2>
            </div>
            <button type="button">Export CSV</button>
          </div>

          <div class="lead-list">
            {leads.map((lead) => (
              <article class:list={["lead", lead.id === selected.id && "active"]}>
                <div class="lead-top">
                  <div>
                    <h3>{lead.name}</h3>
                    <p>{lead.title} · {lead.company}</p>
                  </div>
                  <div class="score">
                    <strong>{scoreLabel(lead)}</strong>
                    <span>{lead.band}</span>
                  </div>
                </div>
                <p class="reason">{lead.reason}</p>
                <p class="hook">{groundedHook(lead)}</p>
                <div class="tags">
                  <span>{lead.confidence}</span>
                  <span>{lead.owner}</span>
                  {hasOnlyWeakOpenIntent(lead) && <span class="warn">Weak opens only</span>}
                </div>
              </article>
            ))}
          </div>
        </div>

        <aside class="audit" aria-label="RevOps audit panel">
          <p class="eyebrow">RevOps audit</p>
          <h2>{selected.company}</h2>
          <dl>
            <div><dt>Score</dt><dd>{scoreLabel(selected)} · {selected.band}</dd></div>
            <div><dt>Confidence</dt><dd>{selected.confidence}</dd></div>
            <div><dt>CRM owner</dt><dd>{selected.owner}</dd></div>
            <div><dt>Source</dt><dd>{selected.source}</dd></div>
          </dl>

          <h3>Score breakdown</h3>
          <div class="bars">
            {Object.entries(selected.scoreBreakdown).map(([label, value]) => (
              <div>
                <span>{label}</span>
                <progress value={value} max={Math.max(totalScore, 1)}></progress>
                <strong>{value}</strong>
              </div>
            ))}
          </div>

          <h3>Sources</h3>
          <ul class="sources">
            <li>CRM: {selected.stage}</li>
            <li>Enrichment: {freshnessLabel(selected.enrichment.lastUpdatedDaysAgo)}</li>
            <li>Intent: {selected.intent.demoRequest ? "Demo request" : selected.intent.pricingPageVisit ? "Pricing page visit" : selected.intent.surge ? "Category surge" : selected.intent.opens ? `${selected.intent.opens} opens` : "No verified intent"}</li>
            <li>Public signal: {selected.publicSignal ? `${selected.publicSignal.label} (${selected.publicSignal.source})` : "Public signal not found"}</li>
          </ul>

          <div class:list={["writeback", isWritebackEligible(selected) ? "ok" : "hold"]}>
            <span>CRM writeback</span>
            <strong>{selected.writeback.decision}</strong>
            <p>{selected.writeback.reason}</p>
          </div>
        </aside>
      </section>

      <section class="lower">
        <article>
          <p class="eyebrow">Agent flow</p>
          <h2>Required tool order</h2>
          <ol class="timeline">
            {toolRun.map((tool) => <li>{tool}</li>)}
          </ol>
        </article>
        <article>
          <p class="eyebrow">Safeguards</p>
          <h2>Current checks</h2>
          <ul class="checks">
            <li>LLM explains the deterministic score but never calculates it.</li>
            <li>Hooks fall back when no verified public or intent signal exists.</li>
            <li>Email opens alone stay weak and cannot justify Hot status.</li>
            <li>Stale enrichment is flagged for review before CRM writeback.</li>
          </ul>
        </article>
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body {
    margin: 0;
    color: #172033;
    background: #f6f8fb;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }
  main {
    width: min(1440px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 48px;
  }
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 24px;
    align-items: end;
    margin-bottom: 24px;
  }
  h1, h2, h3, p { margin: 0; }
  h1 { max-width: 760px; font-size: clamp(2rem, 4vw, 4rem); line-height: 1; letter-spacing: 0; }
  h2 { font-size: 1.3rem; }
  h3 { font-size: 1rem; }
  .hero p:last-child { max-width: 760px; margin-top: 14px; color: #536079; font-size: 1.05rem; }
  .eyebrow {
    margin-bottom: 8px;
    color: #3559d6;
    font-size: .76rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .run-card, .metrics article, .lead, .audit, .lower article {
    border: 1px solid #dfe5f0;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 8px 24px rgba(31, 45, 71, .06);
  }
  .run-card { padding: 18px; }
  .run-card span, .run-card small, .metrics span, dt, .tags span, .writeback span { color: #68758b; font-size: .82rem; }
  .run-card strong { display: block; margin: 6px 0; font-size: 1.3rem; }
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin-bottom: 20px;
  }
  .metrics article { padding: 16px; }
  .metrics strong { display: block; margin-top: 6px; font-size: 2rem; }
  .split {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(340px, .75fr);
    gap: 20px;
    align-items: start;
  }
  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    margin-bottom: 12px;
  }
  button {
    border: 1px solid #cfd7e6;
    border-radius: 8px;
    background: #fff;
    padding: 10px 14px;
    color: #172033;
    font-weight: 700;
  }
  .lead-list { display: grid; gap: 12px; }
  .lead { padding: 16px; }
  .lead.active { border-color: #3559d6; }
  .lead-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }
  .lead-top p, .reason, .hook { color: #536079; }
  .reason { margin-top: 12px; }
  .hook { margin-top: 8px; font-weight: 700; }
  .score { text-align: right; white-space: nowrap; }
  .score strong { display: block; font-size: 1.2rem; }
  .score span {
    color: #3559d6;
    font-size: .82rem;
    font-weight: 800;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .tags span {
    border-radius: 999px;
    background: #eef2f8;
    padding: 5px 9px;
  }
  .tags .warn { background: #fff4dc; color: #7c5600; }
  .audit {
    position: sticky;
    top: 16px;
    padding: 20px;
  }
  dl {
    display: grid;
    gap: 10px;
    margin: 18px 0;
  }
  dl div {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    border-bottom: 1px solid #edf1f7;
    padding-bottom: 10px;
  }
  dd { margin: 0; font-weight: 800; text-align: right; }
  .bars, .sources { margin: 12px 0 22px; }
  .bars div {
    display: grid;
    grid-template-columns: 92px 1fr 34px;
    gap: 10px;
    align-items: center;
    margin-bottom: 10px;
    color: #536079;
    font-size: .9rem;
  }
  progress { width: 100%; accent-color: #3559d6; }
  .sources, .checks { padding-left: 18px; color: #536079; }
  .sources li, .checks li { margin: 8px 0; }
  .writeback {
    border-radius: 8px;
    padding: 14px;
  }
  .writeback.ok { background: #eaf7ef; }
  .writeback.hold { background: #fff4dc; }
  .writeback strong { display: block; margin: 4px 0; }
  .lower {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }
  .lower article { padding: 20px; }
  .timeline {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
    margin: 16px 0 0;
    padding: 0;
    list-style-position: inside;
  }
  .timeline li {
    border-radius: 8px;
    background: #eef2f8;
    padding: 10px;
    overflow-wrap: anywhere;
    font-size: .82rem;
    font-weight: 700;
  }
  @media (max-width: 980px) {
    .hero, .split, .lower { grid-template-columns: 1fr; }
    .audit { position: static; }
    .timeline { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    main { width: min(100% - 20px, 1440px); padding-top: 18px; }
    .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .lead-top, .section-heading { align-items: flex-start; }
    .lead-top { flex-direction: column; }
    .score { text-align: left; }
  }
</style>
