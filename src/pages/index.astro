---
import { dashboardPromptVersion, rankDashboardLeads } from "../lib/dashboard";
import { defaultConfigVersion } from "../lib/config";
import { leads as fixtureLeads } from "../data/leads";
import {
  groundedHook,
  groundedHookEvidence,
  hasOnlyWeakOpenIntent,
  requiredToolSteps,
  scoreLabel,
  type Evidence,
  type LeadPacket,
  type ScoreBreakdown
} from "../lib/contextai";

const dashboardApiUrl = (import.meta.env.PUBLIC_CONTEXTAI_API_URL ?? "http://127.0.0.1:4000").replace(/\/$/, "");
let leads: LeadPacket[] = [];
let dashboardError = "";
if (import.meta.env.DEV) {
  try {
    const response = await fetch(`${dashboardApiUrl}/dashboard`);
    const result = await response.json() as { leads?: LeadPacket[]; error?: string };
    if (!response.ok) throw new Error(result.error || "HubSpot dashboard request failed");
    leads = result.leads ?? [];
  } catch (error) {
    leads = fixtureLeads;
    dashboardError = error instanceof Error ? error.message : "HubSpot dashboard is unavailable";
  }
}

const queueLeads = rankDashboardLeads(leads);
const selected = queueLeads[0];
const scoreCaps = defaultConfigVersion.config.categoryWeights;
const bandThresholds = defaultConfigVersion.config.bandThresholds;
const scoreKeys = Object.keys(scoreCaps) as Array<keyof ScoreBreakdown>;
const hot = leads.filter(({ priority_band }) => priority_band === "Hot").length;
const review = leads.filter(({ priority_band }) => priority_band === "Needs Manual Review").length;
const partial = leads.filter((lead) => Object.values(lead.tool_status).some(({ status }) => !["success", "no_result"].includes(status))).length;
const writebackReview = leads.filter(({ writeback_plan }) => writeback_plan?.decision === "Review").length;

const humanize = (value: string) => value
  .replaceAll("_", " ")
  .replaceAll(/\b\w/g, (letter) => letter.toUpperCase())
  .replaceAll(/\bCrm\b/g, "CRM")
  .replaceAll(/\bIcp\b/g, "ICP")
  .replaceAll(/\bId\b/g, "ID")
  .replaceAll(/\bUrl\b/g, "URL");
const formatTimestamp = (value: string) => new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
  timeZone: "UTC",
  timeZoneName: "short"
}).format(new Date(value));
const bandSlug = (value: string) => value.toLowerCase().replaceAll(" ", "-");
const allEvidence = (lead: LeadPacket): Evidence[] => [
  ...lead.crm_context.evidence,
  ...lead.enrichment_fields.evidence,
  ...lead.intent_signals.evidence,
  ...lead.engagement_signals.evidence,
  ...lead.public_signals.flatMap(({ evidence }) => evidence),
  ...lead.validation_evidence
];
const evidenceDate = (item: Evidence) => item.source_published_at ?? item.source_updated_at ?? item.retrieved_at;
const evidenceAge = (lead: LeadPacket, item: Evidence) => {
  const days = Math.max(0, Math.floor((Date.parse(lead.evaluation_timestamp) - Date.parse(evidenceDate(item))) / 86_400_000));
  return days === 0 ? "Today" : `${days} ${days === 1 ? "day" : "days"} old`;
};
const evidenceLedger = (lead: LeadPacket) => {
  const evidenceById = new Map(allEvidence(lead).map((item) => [item.evidence_id, item]));
  return lead.allowed_claims.map((claim) => ({
    ...claim,
    evidence: claim.evidence_ids.flatMap((id) => evidenceById.get(id) ?? [])
  }));
};
const approvedSources = (lead: LeadPacket) => [...new Set(evidenceLedger(lead).flatMap(({ evidence }) => evidence.map(({ source_name }) => source_name)))];
const topDriver = (lead: LeadPacket) => {
  if (lead.priority_band === "Needs Manual Review") {
    if (lead.manual_review_reasons.includes("source_conflict")) return "Source conflict";
    if (lead.manual_review_reasons.includes("invalid_source_result")) return "Enrichment unavailable";
    return "Required data missing";
  }
  if (lead.engagement_signals.demo_request || lead.engagement_signals.pricing_page_visit) return "Demo + pricing activity";
  if (lead.intent_signals.surge) return "Category intent surge";
  if (hasOnlyWeakOpenIntent(lead)) return "Weak opens only";
  if (lead.public_signals.length) return lead.public_signals[0].label;
  return "Verified fit";
};
const sourceGroups = (lead: LeadPacket) => {
  const approvedIds = new Set(lead.allowed_claims.flatMap(({ evidence_ids }) => evidence_ids));
  return allEvidence(lead)
    .filter(({ evidence_id }) => approvedIds.has(evidence_id))
    .reduce<Record<string, number>>((groups, { source_type }) => ({ ...groups, [source_type]: (groups[source_type] ?? 0) + 1 }), {});
};
const eventPackets = Object.fromEntries(leads.map((lead) => [lead.lead_id, {
  request_id: lead.request_id,
  evaluation_id: lead.evaluation_id,
  lead_id: lead.lead_id,
  account_id: lead.account_id,
  score_version: lead.score_version,
  priority_score: lead.priority_score,
  priority_band: lead.priority_band
}]));
const safeJson = JSON.stringify(eventPackets).replaceAll("<", "\\u003c");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>ContextAI Lead Triage</title>
  </head>
  <body data-api-origin={dashboardApiUrl} data-config-version={defaultConfigVersion.id} data-prompt-version={dashboardPromptVersion}>
    <a class="skip-link" href="#queue-workspace">Skip to lead queue</a>
    <div class="app-shell" data-app-shell>
      <aside class="app-nav" aria-label="ContextAI navigation">
        <a class="brand" href="/" aria-label="ContextAI dashboard">
          <span aria-hidden="true">C</span>
          <strong>ContextAI</strong>
        </a>
        <nav>
          <button type="button" class="nav-item active" data-nav-view="today" aria-current="page"><span>HubSpot</span><strong>{leads.length}</strong></button>
          <button type="button" class="nav-item" data-nav-view="review"><span>Manual review</span><strong>{review}</strong></button>
          <button type="button" class="nav-item" data-nav-tab="run"><span>Runs</span><strong>{partial}</strong></button>
          <button type="button" class="nav-item" data-nav-tab="score"><span>Scoring</span></button>
          <button type="button" class="nav-item" data-nav-tab="evidence"><span>Sources</span></button>
          <button type="button" class="nav-item" data-nav-tab="audit"><span>Writeback audit</span><strong>{writebackReview}</strong></button>
          <a class="nav-item" href="/admin"><span>Governance</span></a>
        </nav>
        <div class="nav-account">
          <span aria-hidden="true">HS</span>
          <p><strong>HubSpot</strong><small>Connected CRM</small></p>
        </div>
      </aside>

      <main class="queue-pane" id="queue-workspace" aria-labelledby="queue-title">
        <header class="queue-toolbar">
          <div>
            <h1 id="queue-title">HubSpot lead queue</h1>
            <p>{selected ? `Last analyzed ${formatTimestamp(selected.evaluation_timestamp)} · ${leads.length} evaluated` : "Refresh to analyze current HubSpot contacts"}</p>
          </div>
          <div class="toolbar-controls">
            <label class="search-control">
              <span>Search leads</span>
              <input id="lead-search" type="search" placeholder="Lead or company" autocomplete="off" />
            </label>
            <label class="filter-control">
              <span>Band</span>
              <select id="band-filter">
                <option value="all">All bands</option>
                <option value="Hot">Hot</option>
                <option value="Warm">Warm</option>
                <option value="Cold">Cold</option>
                <option value="Needs Manual Review">Manual review</option>
              </select>
            </label>
            <button type="button" class="quiet-button" data-refresh-queue>Refresh &amp; analyze</button>
          </div>
        </header>

        <section class="run-summary" aria-label="HubSpot analysis summary">
          <p><strong>{hot}</strong><span>Hot leads</span></p>
          <p><strong>{review}</strong><span>Needs manual review</span></p>
          <p><strong>{partial}</strong><span>Partial source run</span></p>
          <p class="run-complete"><strong>{leads.length ? "Run complete" : "Ready to sync"}</strong><span>{leads.length ? "All required steps are terminal" : "Only HubSpot contacts appear"}</span></p>
        </section>

        <div class="queue-status" aria-live="polite">
          <span><strong data-result-count>{leads.length}</strong> leads shown</span>
          <button type="button" data-clear-filters hidden>Clear filters</button>
        </div>

        <div class="loading-ledger" data-loading-ledger hidden aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <span></span>)}
        </div>

        <div class="queue-table-wrap" data-queue-table>
          <table class="lead-table">
            <caption class="visually-hidden">Prioritized leads from the latest morning evaluation</caption>
            <thead><tr><th>Score</th><th>Lead and account</th><th>Top driver</th><th>Owner</th><th>Plan / outcome</th></tr></thead>
            <tbody>
              {queueLeads.map((lead, index) => (
                <tr
                  class:list={[index === 0 && "selected", lead.priority_band === "Needs Manual Review" && "review-row"]}
                  data-lead-row={lead.lead_id}
                  data-search={`${lead.lead_identity.name} ${lead.lead_identity.company} ${lead.lead_identity.title} ${lead.crm_context.owner ?? ""}`.toLowerCase()}
                  data-band={lead.priority_band}
                >
                  <td><strong class={`score score-${bandSlug(lead.priority_band)}`}>{scoreLabel(lead)}</strong><small>{lead.priority_band}</small></td>
                  <td><button type="button" class="lead-select" data-select-lead={lead.lead_id} aria-pressed={index === 0 ? "true" : "false"}><strong>{lead.lead_identity.name}</strong><span>{lead.lead_identity.title} at {lead.lead_identity.company}</span></button></td>
                  <td><strong>{topDriver(lead)}</strong><span>{lead.confidence} confidence</span></td>
                  <td><strong>{lead.crm_context.owner ?? "Unassigned"}</strong><span>{lead.crm_context.source ?? "Data unavailable"}</span></td>
                  <td><strong>{lead.writeback_plan?.decision ?? "Unavailable"} / {lead.writeback_outcome.status}</strong><span>{lead.writeback_plan?.reason ?? "Writeback evaluation unavailable"}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <ol class="mobile-lead-list" data-mobile-list aria-label="Prioritized leads">
          {queueLeads.map((lead, index) => (
            <li
              data-mobile-lead={lead.lead_id}
              data-search={`${lead.lead_identity.name} ${lead.lead_identity.company} ${lead.lead_identity.title} ${lead.crm_context.owner ?? ""}`.toLowerCase()}
              data-band={lead.priority_band}
            >
              <button type="button" data-select-lead={lead.lead_id} aria-pressed={index === 0 ? "true" : "false"}>
                <span class="mobile-score"><strong>{scoreLabel(lead)}</strong><small>{lead.priority_band}</small></span>
                <span class="mobile-identity"><strong>{lead.lead_identity.company}</strong><small>{lead.lead_identity.name}, {lead.lead_identity.title}</small><em>{topDriver(lead)}</em></span>
                <span class="mobile-outcome"><strong>{lead.writeback_outcome.status}</strong><small>{lead.confidence}</small></span>
              </button>
            </li>
          ))}
        </ol>

        <section class="empty-state" data-empty-state hidden={leads.length > 0}>
          <h2>{dashboardError ? "HubSpot data is unavailable" : "No analyzed HubSpot contacts yet"}</h2>
          <p>{dashboardError || "Choose Refresh & analyze to pull current contacts from HubSpot and run the evaluation pipeline."}</p>
          <button type="button" class="primary-button" data-empty-refresh hidden={Boolean(dashboardError)}>Refresh &amp; analyze</button>
        </section>
      </main>

      <aside class="detail-pane" id="lead-detail" aria-label="Selected lead detail">
        <section class="no-selection" data-no-selection hidden={leads.length > 0}>
          <h2>{leads.length ? "Select a lead" : "Waiting for HubSpot"}</h2>
          <p>{leads.length ? "Choose a visible lead to inspect its decision, evidence, CRM context, score, and run audit." : "Refresh the queue to analyze current CRM contacts."}</p>
        </section>

        {queueLeads.map((lead, leadIndex) => {
          const ledger = evidenceLedger(lead);
          const sources = approvedSources(lead);
          const groups = sourceGroups(lead);
          const hook = groundedHook(lead);
          const hookEvidence = groundedHookEvidence(lead);
          const failedTools = requiredToolSteps.filter((step) => !["success", "no_result"].includes(lead.tool_status[step].status));
          const hasDataIssues = lead.manual_review_reasons.length + lead.missing_fields.length + lead.stale_fields.length + lead.source_conflicts.length + failedTools.length > 0;
          const manualReview = lead.priority_band === "Needs Manual Review";
          return (
            <article class="lead-detail" data-lead-detail={lead.lead_id} hidden={leadIndex !== 0}>
              <header class="detail-header">
                <button type="button" class="back-button" data-back-to-queue>Back to queue</button>
                <div>
                  <span>Selected lead</span>
                  <h2 tabindex="-1" data-detail-heading>{lead.lead_identity.company}</h2>
                  <p>{lead.lead_identity.name}, {lead.lead_identity.title}</p>
                </div>
                <div class="detail-score"><strong>{scoreLabel(lead)}</strong><span>{lead.priority_band}</span><small>{lead.confidence} confidence</small></div>
              </header>

              <div class="detail-tabs" role="tablist" aria-label={`${lead.lead_identity.company} details`}>
                {(["decision", "evidence", "crm", "score", "run", "audit"] as const).map((tab, index) => (
                  <button
                    type="button"
                    role="tab"
                    id={`${lead.lead_id}-${tab}-tab`}
                    aria-controls={`${lead.lead_id}-${tab}-panel`}
                    aria-selected={index === 0 ? "true" : "false"}
                    tabindex={index === 0 ? 0 : -1}
                    data-tab={tab}
                  >{humanize(tab)}</button>
                ))}
              </div>

              <div class="detail-scroll">
                <section class="tab-panel decision-panel" role="tabpanel" id={`${lead.lead_id}-decision-panel`} aria-labelledby={`${lead.lead_id}-decision-tab`} data-panel="decision">
                  {manualReview && (
                    <div class="review-notice" role="note"><strong>Manual review required</strong><p>This evaluation has no numeric priority score. Resolve the listed data issues before accepting a recommendation.</p></div>
                  )}
                  <section class="decision-copy">
                    <h3>Why prioritized</h3>
                    <p>{lead.reason}</p>
                    <small>Approved sources: {sources.length ? sources.slice(0, 3).join(", ") : "ContextAI validation only"}</small>
                  </section>
                  <section class:list={["decision-copy", "hook-copy", !hookEvidence && "unavailable"]}>
                    <div><h3>Grounded hook</h3><button type="button" data-copy-hook disabled={!hookEvidence}>Copy</button></div>
                    <p data-hook-text>{hook}</p>
                    <small>{hookEvidence ? `${hookEvidence.source_name} · ${evidenceAge(lead, hookEvidence)} · ${hookEvidence.confidence} confidence` : "No approved recent signal is available for outreach."}</small>
                  </section>
                  {hasOnlyWeakOpenIntent(lead) && (
                    <div class="weak-warning" role="note"><strong>Weak engagement only</strong><p>Email opens are not buying intent and cannot justify Hot status or a grounded hook.</p></div>
                  )}
                  <section class="data-health">
                    <h3>Data health</h3>
                    {!hasDataIssues && <p class="healthy-state">No material missing, stale, conflicting, or failed source data.</p>}
                    {lead.manual_review_reasons.length > 0 && <div><strong>Review reasons</strong><p>{lead.manual_review_reasons.map(humanize).join(", ")}</p></div>}
                    {lead.missing_fields.length > 0 && <div><strong>Missing</strong><p>{lead.missing_fields.map(humanize).join(", ")}</p></div>}
                    {lead.stale_fields.length > 0 && <div><strong>Stale</strong><p>{lead.stale_fields.map(humanize).join(", ")}</p></div>}
                    {lead.source_conflicts.length > 0 && <div><strong>Conflicts</strong><p>{lead.source_conflicts.join(" ")}</p></div>}
                    {failedTools.length > 0 && <div><strong>Source failures</strong><p>{failedTools.map((step) => `${humanize(step)}: ${humanize(lead.tool_status[step].status)}`).join(", ")}</p></div>}
                  </section>
                  <form class="outcome-form" data-outcome-form={lead.lead_id}>
                    <div class="form-heading"><div><h3>Capture rep outcome</h3><p>This records a choice only. ContextAI does not call, send, sequence, enrich, nurture, disqualify, route, score, or write to CRM.</p></div><span>Not emitted</span></div>
                    <fieldset>
                      <legend>Recommendation disposition</legend>
                      <div class="segmented-control">
                        <label class:list={[manualReview && "disabled"]}><input type="radio" name={`disposition-${lead.lead_id}`} value="accepted" required disabled={manualReview} /><span>Accept</span></label>
                        <label><input type="radio" name={`disposition-${lead.lead_id}`} value="overridden" required /><span>Override</span></label>
                        <label><input type="radio" name={`disposition-${lead.lead_id}`} value="ignored" required /><span>Ignore</span></label>
                      </div>
                    </fieldset>
                    <label class="action-select"><span>Observed action (optional)</span><select name="actionType"><option value="">No linked action</option><option value="call">Call</option><option value="email">Email</option><option value="sequence">Sequence</option><option value="manual_enrichment" selected={manualReview}>Manual enrichment</option><option value="nurture">Nurture</option><option value="disqualify">Disqualify</option></select></label>
                    <button type="submit" class="primary-button">Emit outcome events</button>
                    <output data-outcome-status aria-live="polite"></output>
                  </form>
                  <section class="writeback-pair">
                    <div><span>Deterministic plan</span><strong>{lead.writeback_plan?.decision ?? "Data unavailable"}</strong><p>{lead.writeback_plan?.reason ?? "Writeback evaluation did not produce a plan."}</p></div>
                    <div><span>Execution outcome</span><strong>{lead.writeback_outcome.status}</strong><p>{lead.writeback_outcome.reason}</p></div>
                  </section>
                </section>

                <section class="tab-panel evidence-panel" role="tabpanel" id={`${lead.lead_id}-evidence-panel`} aria-labelledby={`${lead.lead_id}-evidence-tab`} data-panel="evidence" hidden>
                  <header class="panel-heading"><div><h3>Approved evidence ledger</h3><p>Only claims approved by the packet contract are displayed.</p></div><strong>{ledger.length} {ledger.length === 1 ? "claim" : "claims"}</strong></header>
                  <dl class="source-summary">
                    {Object.entries(groups).map(([type, count]) => <div><dt>{humanize(type)}</dt><dd>{count}</dd></div>)}
                  </dl>
                  <div class="claim-ledger">
                    {ledger.map((claim, index) => (
                      <article>
                        <span class="claim-number">C{index + 1}</span>
                        <div class="claim-copy"><strong>{claim.text}</strong><p>{claim.evidence_ids.join(", ")}</p></div>
                        <dl>
                          <div><dt>Source</dt><dd>{[...new Set(claim.evidence.map(({ source_name }) => source_name))].join(" + ")}</dd></div>
                          <div><dt>Type</dt><dd>{[...new Set(claim.evidence.map(({ source_type }) => humanize(source_type)))].join(" + ")}</dd></div>
                          <div><dt>Freshness</dt><dd>{claim.evidence.map((item) => evidenceAge(lead, item)).join(" / ")}</dd></div>
                          <div><dt>Confidence</dt><dd>{[...new Set(claim.evidence.map(({ confidence }) => confidence))].join(" / ")}</dd></div>
                        </dl>
                        <details>
                          <summary>Inspect {claim.evidence.length} evidence {claim.evidence.length === 1 ? "record" : "records"}</summary>
                          <ul>{claim.evidence.map((item) => <li><div><strong>{item.source_name}</strong><span>{humanize(item.source_type)} · {formatTimestamp(evidenceDate(item))}</span></div>{item.source_url ? <a href={item.source_url} target="_blank" rel="noreferrer">Open source</a> : <span>Provider record</span>}</li>)}</ul>
                        </details>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="tab-panel crm-panel" role="tabpanel" id={`${lead.lead_id}-crm-panel`} aria-labelledby={`${lead.lead_id}-crm-tab`} data-panel="crm" hidden>
                  <header class="panel-heading"><div><h3>Authoritative CRM context</h3><p>Workflow and association fields remain controlled by HubSpot.</p></div><strong>{lead.account_id ? "Associated" : "No account"}</strong></header>
                  <dl class="definition-grid">
                    <div><dt>Owner</dt><dd>{lead.crm_context.owner ?? "Data unavailable"}</dd></div>
                    <div><dt>Lifecycle stage</dt><dd>{lead.crm_context.lifecycle_stage ?? "Data unavailable"}</dd></div>
                    <div><dt>Routing status</dt><dd>{lead.crm_context.routing_status ?? "Data unavailable"}</dd></div>
                    <div><dt>Open opportunity</dt><dd>{humanize(lead.crm_context.open_opportunity_status)}</dd></div>
                    <div><dt>Company association</dt><dd>{humanize(lead.crm_context.company_association.status)}{lead.crm_context.company_association.basis ? ` (${lead.crm_context.company_association.basis})` : ""}</dd></div>
                    <div><dt>Duplicate state</dt><dd>{humanize(lead.crm_context.duplicate_status)}</dd></div>
                    <div><dt>Domain state</dt><dd>{humanize(lead.crm_context.domain_status)}</dd></div>
                    <div><dt>Account ID</dt><dd class="mono">{lead.account_id ?? "None"}</dd></div>
                  </dl>
                  <section class="enrichment-summary"><h3>Normalized enrichment</h3><dl><div><dt>Employees</dt><dd>{lead.enrichment_fields.employees ?? "Data unavailable"}</dd></div><div><dt>Revenue band</dt><dd>{lead.enrichment_fields.revenue_band ?? "Data unavailable"}</dd></div><div><dt>Technology</dt><dd>{lead.enrichment_fields.tech_stack.length ? lead.enrichment_fields.tech_stack.join(", ") : "Data unavailable"}</dd></div><div><dt>Freshness</dt><dd>{lead.enrichment_fields.last_updated_days_ago === undefined ? "Data unavailable" : `${lead.enrichment_fields.last_updated_days_ago} days`}</dd></div></dl></section>
                  <section class="writeback-pair"><div><span>Plan</span><strong>{lead.writeback_plan?.decision ?? "Data unavailable"}</strong><p>{lead.writeback_plan?.reason ?? "No deterministic plan available."}</p></div><div><span>Outcome</span><strong>{lead.writeback_outcome.status}</strong><p>{lead.writeback_outcome.reason}</p></div></section>
                </section>

                <section class="tab-panel score-panel" role="tabpanel" id={`${lead.lead_id}-score-panel`} aria-labelledby={`${lead.lead_id}-score-tab`} data-panel="score" hidden>
                  <header class="panel-heading"><div><h3>Deterministic score</h3><p>The LLM explains this score but never calculates or changes it.</p></div><strong>{scoreLabel(lead)}</strong></header>
                  {manualReview && <div class="review-notice"><strong>Nonnumeric override</strong><p>Needs Manual Review takes precedence over the numeric bands. Category evidence is shown without calculating a total.</p></div>}
                  <div class="score-ledger">
                    {scoreKeys.map((key) => <div><span>{humanize(key)}</span><meter min="0" max={scoreCaps[key]} value={lead.score_breakdown[key]} aria-label={`${humanize(key)} ${lead.score_breakdown[key]} of ${scoreCaps[key]}`}></meter><strong>{lead.score_breakdown[key]} / {scoreCaps[key]}</strong></div>)}
                  </div>
                  <dl class="version-grid"><div><dt>Score version</dt><dd>{lead.score_version}</dd></div><div><dt>Config version</dt><dd>{defaultConfigVersion.id}</dd></div><div><dt>Cold</dt><dd>{`≥ ${bandThresholds.Cold} and < ${bandThresholds.Warm}`}</dd></div><div><dt>Warm</dt><dd>{`≥ ${bandThresholds.Warm} and < ${bandThresholds.Hot}`}</dd></div><div><dt>Hot</dt><dd>{`≥ ${bandThresholds.Hot} and ≤ 100`}</dd></div><div><dt>Manual review</dt><dd>Nonnumeric override</dd></div></dl>
                </section>

                <section class="tab-panel run-panel" role="tabpanel" id={`${lead.lead_id}-run-panel`} aria-labelledby={`${lead.lead_id}-run-tab`} data-panel="run" hidden>
                  <header class="panel-heading"><div><h3>Evaluation run</h3><p>Every required step has exactly one terminal status.</p></div><strong>{failedTools.length ? "Partial" : "Complete"}</strong></header>
                  <dl class="identifier-grid"><div><dt>Request ID</dt><dd>{lead.request_id}</dd></div><div><dt>Evaluation ID</dt><dd>{lead.evaluation_id}</dd></div><div><dt>Evaluated</dt><dd>{formatTimestamp(lead.evaluation_timestamp)}</dd></div><div><dt>Prompt</dt><dd>{dashboardPromptVersion}</dd></div></dl>
                  <ol class="tool-ledger">
                    {requiredToolSteps.map((step) => { const result = lead.tool_status[step]; return <li><span>{humanize(step)}</span><strong class={`status-${result.status}`}>{humanize(result.status)}</strong><time datetime={result.completed_at}>{formatTimestamp(result.completed_at)}</time><p>{result.detail ?? (result.status === "success" ? "Completed with normalized data." : "Completed with no matching data.")}</p></li>; })}
                  </ol>
                </section>

                <section class="tab-panel audit-panel" role="tabpanel" id={`${lead.lead_id}-audit-panel`} aria-labelledby={`${lead.lead_id}-audit-tab`} data-panel="audit" hidden>
                  <header class="panel-heading"><div><h3>Audit view</h3><p>Plans, observed outcomes, and emitted UI events remain distinct.</p></div><strong>{lead.writeback_outcome.status}</strong></header>
                  <section class="writeback-pair"><div><span>Deterministic plan</span><strong>{lead.writeback_plan?.decision ?? "Data unavailable"}</strong><p>{lead.writeback_plan?.reason ?? "No plan was produced."}</p></div><div><span>Authoritative execution outcome</span><strong>{lead.writeback_outcome.status}</strong><p>{lead.writeback_outcome.reason}</p></div></section>
                  <dl class="identifier-grid"><div><dt>Evaluation</dt><dd>{lead.evaluation_id}</dd></div><div><dt>Score / config</dt><dd>{lead.score_version} / {defaultConfigVersion.id}</dd></div><div><dt>Writeback recorded</dt><dd>{formatTimestamp(lead.writeback_outcome.recorded_at)}</dd></div><div><dt>Actor</dt><dd>HubSpot analysis worker</dd></div></dl>
                  <section class="session-events"><h3>UI events emitted this session</h3><p>No telemetry endpoint is connected to this static surface. Valid #9 events are emitted through the browser boundary for the recorder to consume.</p><ol data-session-events><li>No rep outcome events emitted.</li></ol></section>
                </section>
              </div>
            </article>
          );
        })}
      </aside>
    </div>
    <div class="sr-status" aria-live="polite" data-live-status></div>
    <script type="application/json" id="event-packets" set:html={safeJson}></script>
  </body>
</html>

<script>
  import { dashboardOutcomeEvents, dashboardViewEvents, rankDashboardLeads } from "../lib/dashboard.ts";
  import type { LeadPacket } from "../lib/contextai.ts";
  import type { ActionType, PilotEvent } from "../lib/instrumentation.ts";

  type EventPacket = Parameters<typeof dashboardViewEvents>[0]["packet"];
  type DashboardResponse = { leads?: LeadPacket[]; analyzed?: number; failed?: number; error?: string };
  const packetElement = document.querySelector<HTMLScriptElement>("#event-packets");
  const packets = JSON.parse(packetElement?.textContent ?? "{}") as Record<string, EventPacket>;
  const shell = document.querySelector<HTMLElement>("[data-app-shell]");
  const search = document.querySelector<HTMLInputElement>("#lead-search");
  const band = document.querySelector<HTMLSelectElement>("#band-filter");
  const live = document.querySelector<HTMLElement>("[data-live-status]");
  const queuePane = document.querySelector<HTMLElement>("#queue-workspace");
  const detailPane = document.querySelector<HTMLElement>("#lead-detail");
  const noSelection = document.querySelector<HTMLElement>("[data-no-selection]");
  const desktopRows = [...document.querySelectorAll<HTMLElement>("[data-lead-row]")];
  const mobileRows = [...document.querySelectorAll<HTMLElement>("[data-mobile-lead]")];
  const detailPanels = [...document.querySelectorAll<HTMLElement>("[data-lead-detail]")];
  const selectButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-select-lead]")];
  const mobile = matchMedia("(max-width: 820px)");
  const eventSessionId = crypto.randomUUID();
  const emittedViews = new Set<string>();
  let selectedId = detailPanels.find((panel) => !panel.hidden)?.dataset.leadDetail ?? null;
  let activeTab = "decision";
  let originButton: HTMLButtonElement | null = null;
  let queueScroll = 0;
  let clientQueueActive = false;

  const announce = (message: string) => { if (live) live.textContent = message; };
  const fetchDashboard = async (path: string, init?: RequestInit) => {
    const apiOrigin = document.body.dataset.apiOrigin?.replace(/\/$/, "") ?? "";
    const sessionToken = sessionStorage.getItem("contextai.session-token");
    const response = await fetch(`${apiOrigin}${path}`, {
      ...init,
      headers: { ...init?.headers, ...(sessionToken ? { Authorization: `Bearer ${sessionToken}` } : {}) },
    });
    const result = await response.json() as DashboardResponse;
    if (!response.ok) throw new Error(result.error || "HubSpot dashboard request failed");
    return result;
  };
  const textElement = (tag: keyof HTMLElementTagNameMap, text: string, className?: string) => {
    const node = document.createElement(tag);
    node.textContent = text;
    if (className) node.className = className;
    return node;
  };
  const renderClientLeads = (leads: LeadPacket[]) => {
    const empty = document.querySelector<HTMLElement>("[data-empty-state]");
    if (!empty) return;
    clientQueueActive = true;
    const ordered = rankDashboardLeads(leads);
    const list = document.createElement("ol");
    list.className = "client-lead-list";
    for (const lead of ordered) {
      const item = document.createElement("li");
      item.dataset.clientLead = lead.lead_id;
      item.dataset.search = `${lead.lead_identity.name} ${lead.lead_identity.company} ${lead.lead_identity.title} ${lead.crm_context.owner ?? ""}`.toLowerCase();
      item.dataset.band = lead.priority_band;
      const heading = document.createElement("div");
      heading.append(
        textElement("strong", lead.lead_identity.company),
        textElement("span", `${lead.lead_identity.name}, ${lead.lead_identity.title}`)
      );
      item.append(
        textElement("strong", lead.priority_score === null ? "Review" : String(lead.priority_score), `score score-${lead.priority_band.toLowerCase().replaceAll(" ", "-")}`),
        heading,
        textElement("span", lead.priority_band),
        textElement("p", lead.reason),
        textElement("small", `${lead.crm_context.owner ?? "Unassigned"} · ${lead.writeback_outcome.status}`)
      );
      list.append(item);
    }
    empty.replaceChildren(
      textElement("h2", ordered.length ? "Analyzed HubSpot contacts" : "No contacts were successfully analyzed"),
      textElement("p", ordered.length ? "Live results loaded from the ContextAI runtime." : "Review the refresh errors and try again."),
      ...(ordered.length ? [list] : [])
    );
    empty.hidden = false;
    document.querySelector<HTMLElement>("[data-queue-table]")?.setAttribute("hidden", "");
    document.querySelector<HTMLElement>("[data-mobile-list]")?.setAttribute("hidden", "");
    const count = document.querySelector<HTMLElement>("[data-result-count]");
    if (count) count.textContent = String(ordered.length);
    if (noSelection) {
      noSelection.hidden = false;
      noSelection.querySelector("h2")!.textContent = ordered.length ? "Live HubSpot results" : "Waiting for HubSpot";
      noSelection.querySelector("p")!.textContent = ordered.length ? "The current analyzed contacts are shown in the queue." : "Refresh the queue to analyze current CRM contacts.";
    }
    applyFilters();
  };
  const emit = (events: PilotEvent[]) => events.forEach((event) => window.dispatchEvent(new CustomEvent("contextai:pilot-event", { detail: event })));
  const emitView = (leadId: string) => {
    if (emittedViews.has(leadId) || !packets[leadId]) return;
    emittedViews.add(leadId);
    emit(dashboardViewEvents({
      packet: packets[leadId],
      tenantId: "pilot-workspace",
      actorType: "rep",
      actorId: "dashboard-user",
      configVersion: document.body.dataset.configVersion ?? "score-v0.1",
      occurredAt: new Date().toISOString(),
      idempotencySeed: `dashboard:${eventSessionId}:${packets[leadId].evaluation_id}:view`
    }));
  };
  const activeDetail = () => detailPanels.find((panel) => panel.dataset.leadDetail === selectedId) ?? null;
  const updateHash = () => {
    if (!selectedId) return;
    history.replaceState(null, "", `#lead=${encodeURIComponent(selectedId)}&tab=${encodeURIComponent(activeTab)}`);
  };
  const activateTab = (panel: HTMLElement, tabName: string, focus = false) => {
    const tabs = [...panel.querySelectorAll<HTMLButtonElement>("[role=tab]")];
    const tab = tabs.find((item) => item.dataset.tab === tabName) ?? tabs[0];
    if (!tab) return;
    activeTab = tab.dataset.tab ?? "decision";
    tabs.forEach((item) => {
      const active = item === tab;
      item.setAttribute("aria-selected", String(active));
      item.tabIndex = active ? 0 : -1;
      const targetId = item.getAttribute("aria-controls");
      const target = targetId ? document.getElementById(targetId) : null;
      if (target) target.hidden = !active;
    });
    if (focus) tab.focus();
    updateHash();
  };
  const showNoSelection = () => {
    selectedId = null;
    detailPanels.forEach((panel) => panel.hidden = true);
    selectButtons.forEach((button) => button.setAttribute("aria-pressed", "false"));
    desktopRows.forEach((row) => row.classList.remove("selected"));
    if (noSelection) noSelection.hidden = false;
  };
  const selectLead = (leadId: string, tabName = "decision", openMobile = true, focusDetail = true) => {
    const panel = detailPanels.find((item) => item.dataset.leadDetail === leadId);
    if (!panel) return;
    selectedId = leadId;
    activeTab = tabName;
    if (noSelection) noSelection.hidden = true;
    detailPanels.forEach((item) => item.hidden = item !== panel);
    desktopRows.forEach((row) => row.classList.toggle("selected", row.dataset.leadRow === leadId));
    selectButtons.forEach((button) => button.setAttribute("aria-pressed", String(button.dataset.selectLead === leadId)));
    activateTab(panel, tabName);
    if (mobile.matches && openMobile) {
      queueScroll = window.scrollY;
      shell?.classList.add("mobile-detail");
      if (focusDetail) panel.querySelector<HTMLElement>("[data-back-to-queue]")?.focus();
      window.scrollTo({ top: 0, behavior: matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth" });
      emitView(leadId);
    } else if (!mobile.matches) emitView(leadId);
    announce(`${panel.querySelector("h2")?.textContent ?? "Lead"} selected.`);
    updateHash();
  };
  const clientRows = () => [...document.querySelectorAll<HTMLElement>("[data-client-lead]")];
  const activeQueueRows = () => clientQueueActive ? clientRows() : desktopRows;
  const visibleLeadIds = () => activeQueueRows().filter((row) => !row.hidden).map((row) => row.dataset.clientLead ?? row.dataset.leadRow ?? "");
  const applyFilters = () => {
    const query = search?.value.trim().toLowerCase() ?? "";
    const selectedBand = band?.value ?? "all";
    const matches = (item: HTMLElement) => (!query || item.dataset.search?.includes(query)) && (selectedBand === "all" || item.dataset.band === selectedBand);
    const liveRows = clientRows();
    desktopRows.forEach((row) => row.hidden = clientQueueActive || !matches(row));
    mobileRows.forEach((row) => row.hidden = clientQueueActive || !matches(row));
    liveRows.forEach((row) => row.hidden = !matches(row));
    const visible = visibleLeadIds();
    const count = document.querySelector<HTMLElement>("[data-result-count]");
    if (count) count.textContent = String(visible.length);
    const filtered = Boolean(query || selectedBand !== "all");
    document.querySelectorAll<HTMLElement>("[data-clear-filters]").forEach((button) => button.hidden = !filtered);
    const empty = document.querySelector<HTMLElement>("[data-empty-state]");
    if (empty) empty.hidden = clientQueueActive ? false : visible.length > 0;
    if (selectedId && !visible.includes(selectedId)) showNoSelection();
    announce(`${visible.length} ${visible.length === 1 ? "lead" : "leads"} shown.`);
  };
  const clearFilters = () => { if (search) search.value = ""; if (band) band.value = "all"; applyFilters(); };

  selectButtons.forEach((button) => button.addEventListener("click", () => {
    originButton = button;
    selectLead(button.dataset.selectLead ?? "");
  }));
  desktopRows.forEach((row) => row.addEventListener("click", (event) => {
    if ((event.target as HTMLElement).closest("button")) return;
    selectLead(row.dataset.leadRow ?? "", "decision", false, false);
  }));
  search?.addEventListener("input", applyFilters);
  band?.addEventListener("change", applyFilters);
  document.querySelectorAll<HTMLButtonElement>("[data-clear-filters]").forEach((button) => button.addEventListener("click", clearFilters));

  document.querySelectorAll<HTMLButtonElement>("[data-nav-view]").forEach((button) => button.addEventListener("click", () => {
    document.querySelectorAll("[data-nav-view], [data-nav-tab]").forEach((item) => item.classList.remove("active"));
    button.classList.add("active");
    if (button.dataset.navView === "today") clearFilters();
    if (button.dataset.navView === "review") {
      if (search) search.value = "";
      if (band) band.value = "Needs Manual Review";
      applyFilters();
      const first = visibleLeadIds()[0];
      if (first && !mobile.matches) selectLead(first, "decision", false, false);
    }
    shell?.classList.remove("mobile-detail");
    queuePane?.focus({ preventScroll: true });
  }));
  document.querySelectorAll<HTMLButtonElement>("[data-nav-tab]").forEach((button) => button.addEventListener("click", () => {
    document.querySelectorAll("[data-nav-view], [data-nav-tab]").forEach((item) => item.classList.remove("active"));
    button.classList.add("active");
    const leadId = selectedId ?? visibleLeadIds()[0];
    if (leadId) selectLead(leadId, button.dataset.navTab ?? "decision");
  }));

  detailPanels.forEach((panel) => {
    const tabs = [...panel.querySelectorAll<HTMLButtonElement>("[role=tab]")];
    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activateTab(panel, tab.dataset.tab ?? "decision"));
      tab.addEventListener("keydown", (event) => {
        const keys = ["ArrowLeft", "ArrowRight", "Home", "End"];
        if (!keys.includes(event.key)) return;
        event.preventDefault();
        const nextIndex = event.key === "Home" ? 0 : event.key === "End" ? tabs.length - 1 : (index + (event.key === "ArrowRight" ? 1 : -1) + tabs.length) % tabs.length;
        activateTab(panel, tabs[nextIndex]?.dataset.tab ?? "decision", true);
      });
    });
  });
  document.querySelectorAll<HTMLButtonElement>("[data-back-to-queue]").forEach((button) => button.addEventListener("click", () => {
    shell?.classList.remove("mobile-detail");
    window.scrollTo({ top: queueScroll, behavior: "auto" });
    originButton?.focus({ preventScroll: true });
  }));
  document.querySelectorAll<HTMLButtonElement>("[data-copy-hook]").forEach((button) => button.addEventListener("click", async () => {
    const text = button.closest(".hook-copy")?.querySelector<HTMLElement>("[data-hook-text]")?.textContent?.trim();
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      const previous = button.textContent;
      button.textContent = "Copied";
      announce("Grounded hook copied.");
      setTimeout(() => button.textContent = previous, 1200);
    } catch {
      announce("Copy failed. Select the hook text and copy it manually.");
    }
  }));

  document.querySelectorAll<HTMLFormElement>("[data-outcome-form]").forEach((form) => {
    const action = form.elements.namedItem("actionType") as HTMLSelectElement | null;
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const leadId = form.dataset.outcomeForm ?? "";
      const packet = packets[leadId];
      const disposition = new FormData(form).get(`disposition-${leadId}`);
      if (!packet || !["accepted", "ignored", "overridden"].includes(String(disposition))) return;
      const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
      const output = form.querySelector<HTMLOutputElement>("[data-outcome-status]");
      const actionType = action?.value ? action.value as ActionType : undefined;
      if (button) button.disabled = true;
      try {
        const events = dashboardOutcomeEvents({
          packet,
          disposition: disposition as "accepted" | "ignored" | "overridden",
          actionType,
          tenantId: "pilot-workspace",
          actorType: "rep",
          actorId: "dashboard-user",
          configVersion: document.body.dataset.configVersion ?? "score-v0.1",
          occurredAt: new Date().toISOString(),
          idempotencySeed: `dashboard:${eventSessionId}:${packet.evaluation_id}:${String(disposition)}:${actionType ?? "none"}`
        });
        emit(events);
        const list = activeDetail()?.querySelector<HTMLOListElement>("[data-session-events]");
        if (list) {
          list.replaceChildren(...events.map((pilotEvent) => {
            const item = document.createElement("li");
            item.textContent = `${pilotEvent.name}: ${pilotEvent.name === "recommendation.disposition" ? pilotEvent.data.disposition : pilotEvent.data.actionType}`;
            return item;
          }));
        }
        if (output) output.textContent = `${events.length} valid event${events.length === 1 ? "" : "s"} emitted. No external action was executed.`;
        announce(output?.textContent ?? "Outcome events emitted.");
      } catch (error) {
        if (output) output.textContent = `Event emission failed: ${error instanceof Error ? error.message : String(error)}`;
        if (button) button.disabled = false;
      }
    });
  });

  const refreshQueue = async (button: HTMLButtonElement) => {
    const loading = document.querySelector<HTMLElement>("[data-loading-ledger]");
    const table = document.querySelector<HTMLElement>("[data-queue-table]");
    const list = document.querySelector<HTMLElement>("[data-mobile-list]");
    const previous = button.textContent;
    button.disabled = true;
    button.textContent = "Analyzing…";
    shell?.classList.add("is-loading");
    queuePane?.setAttribute("aria-busy", "true");
    if (loading) loading.hidden = false;
    if (table) table.hidden = true;
    if (list) list.hidden = true;
    announce("Pulling contacts from HubSpot and running analysis.");
    try {
      const result = await fetchDashboard("/dashboard/refresh", { method: "POST" });
      announce(`Analyzed ${result.analyzed ?? 0} HubSpot contacts${result.failed ? `; ${result.failed} failed` : ""}.`);
      renderClientLeads(result.leads ?? []);
      if (loading) loading.hidden = true;
      queuePane?.setAttribute("aria-busy", "false");
      shell?.classList.remove("is-loading");
      button.disabled = false;
      button.textContent = previous;
    } catch (error) {
      if (loading) loading.hidden = true;
      if (table) table.hidden = false;
      if (list) list.hidden = false;
      queuePane?.setAttribute("aria-busy", "false");
      shell?.classList.remove("is-loading");
      button.disabled = false;
      button.textContent = previous;
      applyFilters();
      announce(error instanceof Error ? error.message : "HubSpot analysis failed");
    }
  };
  document.querySelectorAll<HTMLButtonElement>("[data-refresh-queue], [data-empty-refresh]").forEach((button) =>
    button.addEventListener("click", () => refreshQueue(button))
  );

  if (!desktopRows.length) void fetchDashboard("/dashboard")
    .then(({ leads }) => { if (leads?.length) renderClientLeads(leads); })
    .catch((error) => announce(error instanceof Error ? error.message : "HubSpot dashboard is unavailable"));

  const hash = new URLSearchParams(location.hash.slice(1));
  const hashLead = hash.get("lead");
  const hashTab = hash.get("tab") ?? "decision";
  if (hashLead && packets[hashLead]) selectLead(hashLead, hashTab, mobile.matches, false);
  else if (selectedId && !mobile.matches) emitView(selectedId);
  mobile.addEventListener("change", ({ matches }) => {
    if (!matches) { shell?.classList.remove("mobile-detail"); if (selectedId) emitView(selectedId); }
  });
</script>

<style>
  :global(*) { box-sizing: border-box; }
  :global([hidden]) { display: none !important; }
  :global(html) { background: #f5f7f6; }
  :global(body) {
    --bg: #f5f7f6;
    --surface: #ffffff;
    --surface-alt: #eef2f0;
    --surface-strong: #e2eae6;
    --ink: #18231f;
    --muted: #5e6c67;
    --faint: #7a8782;
    --line: #d7dedb;
    --accent: #167052;
    --accent-dark: #0f5c43;
    --accent-soft: #e7f4ef;
    --nav: #15382e;
    --nav-active: #215443;
    --warning: #825400;
    --warning-soft: #fff6df;
    --danger: #9f3434;
    --danger-soft: #fff0ef;
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background: var(--bg);
    font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 14px;
    line-height: 1.45;
  }
  :global(button), :global(input), :global(select) { font: inherit; }
  :global(button), :global(select) { cursor: pointer; }
  :global(button:focus-visible), :global(a:focus-visible), :global(input:focus-visible), :global(select:focus-visible), :global(summary:focus-visible) { outline: 3px solid var(--accent); outline-offset: 2px; }
  :global(button:disabled), :global(select:disabled), :global(input:disabled) { cursor: not-allowed; opacity: .48; }
  :global(h1), :global(h2), :global(h3), :global(p), :global(dl), :global(dd), :global(ol), :global(ul), :global(fieldset) { margin: 0; }
  :global(button) { min-height: 40px; }
  :global(a) { color: inherit; }
  :global(strong), .mono, .score, .detail-score, .score-ledger { font-variant-numeric: tabular-nums; }
  :global(h1), :global(h2), :global(h3) { text-wrap: balance; }
  :global(p) { text-wrap: pretty; }
  .visually-hidden, .sr-status { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .skip-link { position: fixed; z-index: 40; top: 8px; left: 8px; padding: 10px 12px; color: white; background: var(--accent-dark); transform: translateY(-150%); }
  .skip-link:focus { transform: translateY(0); }
  .app-shell { min-height: 100dvh; display: grid; grid-template-columns: 180px minmax(560px, 1fr) minmax(390px, 440px); background: var(--bg); }
  .app-nav { position: sticky; top: 0; height: 100dvh; display: flex; flex-direction: column; padding: 16px 10px; color: #e0eee8; background: var(--nav); }
  .brand { min-height: 46px; display: flex; align-items: center; gap: 9px; padding: 0 8px 16px; color: inherit; text-decoration: none; }
  .brand > span, .nav-account > span { display: grid; place-items: center; border-radius: 50%; color: var(--nav); background: #dcece5; font-weight: 900; }
  .brand > span { width: 29px; height: 29px; }
  .app-nav nav { display: grid; gap: 3px; }
  .nav-item { width: 100%; min-height: 40px; display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 8px 10px; border: 0; border-radius: 5px; color: #b7cbc3; background: transparent; font-weight: 650; text-align: left; }
  .nav-item:hover { color: white; background: #1b493a; }
  .nav-item.active { color: white; background: var(--nav-active); }
  .nav-item strong { color: #d7e9e1; }
  .nav-account { margin-top: auto; display: flex; align-items: center; gap: 8px; padding: 12px 7px 3px; border-top: 1px solid #376052; }
  .nav-account > span { width: 30px; height: 30px; font-size: 11px; }
  .nav-account p { display: grid; }
  .nav-account small { color: #a6bfb5; font-size: 10px; }
  .queue-pane { min-width: 0; padding: 0 20px 24px; border-right: 1px solid var(--line); }
  .queue-toolbar { min-height: 78px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .queue-toolbar h1 { font-size: 20px; letter-spacing: -.015em; }
  .queue-toolbar p { color: var(--muted); font-size: 12px; }
  .toolbar-controls { display: flex; align-items: end; gap: 8px; }
  .search-control, .filter-control { display: grid; gap: 3px; color: var(--muted); font-size: 10px; font-weight: 700; }
  .search-control input, .filter-control select { height: 40px; border: 1px solid var(--line); border-radius: 5px; color: var(--ink); background: var(--surface); }
  .search-control input { width: 180px; padding: 0 10px; }
  .search-control input::placeholder { color: #68756f; }
  .filter-control select { width: 118px; padding: 0 28px 0 9px; }
  .quiet-button { padding: 0 11px; border: 1px solid var(--line); border-radius: 5px; color: var(--ink); background: var(--surface); font-weight: 700; }
  .quiet-button:hover { border-color: var(--accent); color: var(--accent); }
  .run-summary { display: grid; grid-template-columns: repeat(3, minmax(90px, 1fr)) minmax(170px, 1.4fr); margin-bottom: 12px; border: 1px solid var(--line); border-radius: 6px; background: var(--surface); overflow: hidden; }
  .run-summary p { min-height: 59px; display: flex; flex-direction: column; justify-content: center; padding: 8px 14px; border-right: 1px solid var(--line); }
  .run-summary p:last-child { border-right: 0; }
  .run-summary strong { font-size: 19px; }
  .run-summary span { color: var(--muted); font-size: 11px; }
  .run-summary .run-complete { background: var(--accent-soft); }
