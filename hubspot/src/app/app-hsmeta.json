{
  "uid": "contextai-app",
  "type": "app",
  "config": {
    "name": "ContextAI",
    "description": "Grounded lead priority and data quality inside HubSpot CRM.",
    "distribution": "marketplace",
    "auth": {
      "type": "oauth",
      "redirectUrls": ["${CONTEXTAI_API_URL}/oauth/hubspot/callback"],
      "requiredScopes": [
        "oauth",
        "crm.objects.contacts.read",
        "crm.objects.contacts.write",
        "crm.objects.companies.read",
        "crm.objects.owners.read"
      ],
      "optionalScopes": [],
      "conditionallyRequiredScopes": []
    },
    "permittedUrls": {
      "fetch": ["${CONTEXTAI_API_URL}"],
      "iframe": [],
      "img": []
    },
    "support": {
      "supportEmail": "jzeng151@users.noreply.github.com",
      "documentationUrl": "https://github.com/jzeng151/ContextAI/blob/main/hubspot/README.md",
      "supportUrl": "https://github.com/jzeng151/ContextAI/issues"
    }
  }
}
